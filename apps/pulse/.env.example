# Default: live mode. Flip to 'true' to force mock data for demos without a testnet wallet.
NEXT_PUBLIC_USE_MOCK_DATA=false

# Pacifica env: testnet | mainnet
NEXT_PUBLIC_PACIFICA_ENV=testnet

# Comma-separated whale addresses to track (Solana base58 pubkeys)
NEXT_PUBLIC_WHALE_ADDRESSES=HEQ3kHCavWvgFtmBLNaFbDyBrVn9bU4CKctnRhxfrRVS

# Optional: if set, the dashboard can also show YOUR account panel
NEXT_PUBLIC_ACCOUNT_ADDRESS=
