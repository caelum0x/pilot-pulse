# ---------------------------------------------------------------------------
# PacificaPilot — copy to .env.local and fill in.
# ---------------------------------------------------------------------------

# Flip to true to send REAL orders to Pacifica. Requires ADDRESS + PRIVATE_KEY.
# When false (default), every order is routed through the in-process mock
# backend — safe for demos with no funds.
USE_LIVE_PACIFICA=false

# Pacifica network. `testnet` or `mainnet`. Use testnet for hackathon demos.
NEXT_PUBLIC_PACIFICA_ENV=testnet

# Builder code — auto-attached to every market order for fee share.
BUILDER_CODE=HACKATHON_TEST

# HMAC-SHA256 secret used to verify inbound TradingView webhook bodies.
# Rotate regularly. The signer (TradingView proxy / your script) must use
# the SAME secret and send the hex digest as `x-pilot-signature`.
PILOT_WEBHOOK_SECRET=dev-secret-change-me

# Your Pacifica testnet account. Only required when USE_LIVE_PACIFICA=true.
# ADDRESS is a base58 Solana public key.
# PRIVATE_KEY is a base58-encoded 64-byte Solana secret key.
ADDRESS=
PRIVATE_KEY=
