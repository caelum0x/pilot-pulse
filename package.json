{
  "name": "pacifica-hack",
  "version": "0.1.0",
  "private": true,
  "description": "Pacifica Hackathon monorepo — PacificaPulse (analytics) + PacificaPilot (trading bot) sharing one Pacifica TS SDK",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "@types/node": "^22.10.2"
  },
  "engines": {
    "node": ">=20"
  }
}
